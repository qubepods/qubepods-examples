{
  $schema: "https://q64.dev/schema/qube.json5",
  name: "qubepods.examples.counter_backend",
  version: "0.1.0",
  license: "MIT OR Apache-2.0",
  description: "The backend twin: holds the shared count in a WASI key-value store and serves bump/read over wRPC.",
  type: "library",
  entry: "backend.q",

  // Serve this qube's surface (bump/read) over wRPC so the frontend can call it.
  component: {
    emit: true,
    world: "counter-backend",
  },
  rpc: {
    export: true,
  },

  // The one capability the backend asks for: a key-value store (env.kv →
  // wasi:keyvalue). qubepods binds that import to the project's store at boot.
  // `qube audit` shows exactly this — no network, no filesystem.
  effects: {
    declared: ["@kv"],
  },
}
